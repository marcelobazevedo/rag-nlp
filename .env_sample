MODELO_LOCAL=false

# Ative MODELO_LOCAL=true para usar Ollama.
LLM_MODEL=ministral-3:14b
EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_URL=http://host.docker.internal:11434

# Preencha estas variáveis quando MODELO_LOCAL=false.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Ajuste para a mesma dimensão usada pelo modelo de embedding.
PGVECTOR_DIM=768
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=senha_forte_123
POSTGRES_DB=rag_db

STREAMLIT_BIND_ADDRESS=0.0.0.0
CHUNK_SIZE=900
CHUNK_OVERLAP=120
